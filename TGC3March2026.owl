<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.hds.utc.fr/tgc/tbox"
     xml:base="http://www.hds.utc.fr/tgc/tbox"
     xmlns:MC2="http://www.hds.utc.fr/mc2/tbox#"
     xmlns:TCO="http://www.hds.utc.fr/tco/tbox#"
     xmlns:TGC="http://www.hds.utc.fr/tgc/tbox#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:prov="http://www.w3.org/ns/prov#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:sioc="http://rdfs.org/sioc/ns#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:MC2.1="http://www.hds.utc.fr/mc2.1/tbox#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:MC2SOIS="http://www.hds.utc.fr/mc2sois/tbox#">
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:dcat="http://www.w3.org/ns/dcat#"
    <owl:Ontology rdf:about="http://www.hds.utc.fr/tgc/tbox">
        <owl:versionIRI rdf:resource="http://www.hds.utc.fr/tgc/tbox/1.0.0"/>
<rdfs:label xml:lang="en">Teacher in Gamified Context Ontology</rdfs:label>
        <rdfs:comment xml:lang="en">An ontology for modeling teachers, gamified resources, game elements, educational topics, and collaborative sharing spaces in gamified e-learning environments.</rdfs:comment>
        <owl:versionInfo>1.0.0</owl:versionInfo> 
        
        <dcterms:title xml:lang="en">Teacher in Gamified Context Ontology</dcterms:title> 
        <dcterms:description xml:lang="en">The TGC ontology models teachers, pedagogical resources, gamified resources, educational topics, and collaboration spaces in gamified e-learning environments.</dcterms:description>
        <dcterms:creator>Yara Gomaa</dcterms:creator> 
       <dcterms:identifier>https://doi.org/10.5281/zenodo.19048502</dcterms:identifier>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-16</dcterms:issued> 
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-16</dcterms:modified> 
        <dcterms:identifier>http://www.hds.utc.fr/tgc/tbox</dcterms:identifier> 
        <dcat:accessURL rdf:resource="https://github.com/Yara-M-GOMAA/TGC-Ontology"/>
<dcat:downloadURL rdf:resource="https://raw.githubusercontent.com/Yara-M-GOMAA/TGC-Ontology/master/TGC3March2026.owl"/> 
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://rdfs.org/sioc/ns#has_member -->

    <owl:ObjectProperty rdf:about="http://rdfs.org/sioc/ns#has_member">
        <owl:inverseOf rdf:resource="http://rdfs.org/sioc/ns#member_of"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#UserGroup"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#UserAccount"/>
        <rdfs:isDefinedBy>each usergroup has one or more users</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://rdfs.org/sioc/ns#has_usergroup -->

    <owl:ObjectProperty rdf:about="http://rdfs.org/sioc/ns#has_usergroup">
        <owl:inverseOf rdf:resource="http://rdfs.org/sioc/ns#usergroup_of"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#Space"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#UserGroup"/>
        <rdfs:isDefinedBy>each space has user groups</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://rdfs.org/sioc/ns#member_of -->

    <owl:ObjectProperty rdf:about="http://rdfs.org/sioc/ns#member_of">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#UserAccount"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#UserGroup"/>
        <rdfs:isDefinedBy>each user is a member of user group</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://rdfs.org/sioc/ns#usergroup_of -->

    <owl:ObjectProperty rdf:about="http://rdfs.org/sioc/ns#usergroup_of">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#UserGroup"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#Space"/>
        <rdfs:isDefinedBy>each user group is a user group of a space</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#has_user_account -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/mc2/tbox#has_user_account">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#Person"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#UserAccount"/>
        <rdfs:isDefinedBy>person can have one or more user accounts</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#index -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/mc2/tbox#index">
        <owl:inverseOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#indexed_by"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#IndexKey"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/mc2sois/tbox#ReferenceKey"/>
        <rdfs:isDefinedBy>an index key  indexes a resource&apos;s reference key</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#indexed_by -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/mc2/tbox#indexed_by">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2sois/tbox#ReferenceKey"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/mc2/tbox#IndexKey"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#is_visible_for -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/mc2/tbox#is_visible_for">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#IndexKey"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#Space"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/mc2sois/tbox#has_reference -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/mc2sois/tbox#has_reference">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#Resource"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/mc2sois/tbox#ReferenceKey"/>
        <rdfs:isDefinedBy>a resource has a reference key</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/mc2sois/tbox#utilizes -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/mc2sois/tbox#utilizes">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#Activity"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/mc2sois/tbox#ReferenceKey"/>
        <rdfs:isDefinedBy>each activity utilizes an index key</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tco/tbox#consists_of -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tco/tbox#consists_of">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Course"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tco/tbox#Lesson"/>
        <rdfs:isDefinedBy>copurse consists of lessons</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tco/tbox#evolves_in -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tco/tbox#evolves_in">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#EducationalInstitution"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tco/tbox#WorkingEnvironment"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tco/tbox#reuseResource -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tco/tbox#reuseResource">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Lesson"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/mc2/tbox#Resource"/>
        <rdfs:isDefinedBy>each lesson contains one or more resources</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tco/tbox#works_in -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tco/tbox#works_in">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tco/tbox#EducationalInstitution"/>
        <rdfs:isDefinedBy>relation defining the institution where the teacher works</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#CoversTopic -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#CoversTopic">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Lesson"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#EducationalTopic"/>
        <rdfs:isDefinedBy>each lesson covers one or more educational topics</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#aboutEducationalTopic -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#aboutEducationalTopic">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#TopicKnowledge"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#EducationalTopic"/>
        <rdfs:isDefinedBy>Knowledge about the educational topic</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#candidateMentor -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#candidateMentor">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:isDefinedBy>Teacher can be a possible assistance to another teacher</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#concernsACourse -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#concernsACourse">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#ClassroomObjective"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tco/tbox#Course"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#concernsObjective -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#concernsObjective">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#ClassroomObjective"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#Objective"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#containsGameElement -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#containsGameElement">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#CompositeResource"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:isDefinedBy>resource can contain one or more game element</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#designLesson -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#designLesson">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tco/tbox#Lesson"/>
        <rdfs:isDefinedBy>teacher designs the lessons</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#designedWithObjective -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#designedWithObjective">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#Resource"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#Objective"/>
        <rdfs:isDefinedBy>each resource is designed with one or more objectives</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasClassroomObjective -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasClassroomObjective">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#ClassroomObjective"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasDigitalCompetency -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasDigitalCompetency">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#Digital_Competency"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasEducationalTopic -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasEducationalTopic">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Course"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#EducationalTopic"/>
        <rdfs:isDefinedBy>Course has one or more educational topics for each lesson</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasExperience -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasExperience">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#Experience"/>
        <rdfs:isDefinedBy>teacher has experience; pedagogical or gamification</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasGamificationExperience -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasGamificationExperience">
        <rdfs:subPropertyOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#hasExperience"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#GamificationExperience"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasInputPole -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasInputPole">
        <rdfs:subPropertyOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#hasLearningStyle"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Learner"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#InputPole"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasLearningStyle -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasLearningStyle">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Learner"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#LearningStyle"/>
        <rdfs:isDefinedBy>learner has learning style of four dimensions: InputPole, PerceptionPole, ProcessingPole, UnderstandingPole</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasPedagogicalExperience -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasPedagogicalExperience">
        <rdfs:subPropertyOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#hasExperience"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#PedagogicalExperience"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasPerceptionPole -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasPerceptionPole">
        <rdfs:subPropertyOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#hasLearningStyle"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Learner"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#PerceptionPole"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasPlayerType -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasPlayerType">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.hds.utc.fr/tco/tbox#Learner"/>
                    <rdf:Description rdf:about="http://www.hds.utc.fr/tco/tbox#Teacher"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#PlayerType"/>
        <rdfs:isDefinedBy>Teachers and learners (Person) have a player type</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasPreLesson -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasPreLesson">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Lesson"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tco/tbox#Lesson"/>
        <rdfs:isDefinedBy>a lesson can have a pre lesson according to the designed cirriculum of the course</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasPreResource -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasPreResource">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#Resource"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/mc2/tbox#Resource"/>
        <rdfs:isDefinedBy>each resource can have a pre resource according to the designed cirriculum of the course</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasProcessingPole -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasProcessingPole">
        <rdfs:subPropertyOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#hasLearningStyle"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Learner"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#ProcessingPole"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasTargetAudience -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasTargetAudience">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Course"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#Audience"/>
        <rdfs:isDefinedBy>A course has a target audience, which is goup of people</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasTargetedTopicKnowledge -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasTargetedTopicKnowledge">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#Audience"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#TopicKnowledge"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasTopicKnowledge -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasTopicKnowledge">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#Person"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#TopicKnowledge"/>
        <rdfs:isDefinedBy>Knowledge of a person (Teacher and learner) in a topic knowledge</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasUnderstandingPole -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasUnderstandingPole">
        <rdfs:subPropertyOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#hasLearningStyle"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Learner"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#UnderstandingPole"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_SubjectArea -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_SubjectArea">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Course"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#subjectArea"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#isComposedOf -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#isComposedOf">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#Audience"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tco/tbox#Learner"/>
        <rdfs:comment>The audience of learners helps to get insights on the average topic knowledge, preferences, and player types</rdfs:comment>
        <rdfs:isDefinedBy>audience is composed of learners</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#moreExpertThan -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#moreExpertThan">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#offersCourse -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#offersCourse">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#EducationalInstitution"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tco/tbox#Course"/>
        <rdfs:isDefinedBy>Educational institutions offers courses</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#relevantToObjective -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#relevantToObjective">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#Resource"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#BehaviouralObjective"/>
        <rdfs:comment>a behavioural objective can be relevant to a specific resource based on the associated game element(s)</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#requiresLeaderboard -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#requiresLeaderboard">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#Points"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#Leaderboard"/>
        <rdfs:comment>points associated to a resource requires the apropriate leaderboard</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#sharesSpaceWith -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#sharesSpaceWith">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:comment>teachers can share space with another teacher(s)</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#specializedIn -->

    <owl:ObjectProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#specializedIn">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/tgc/tbox#subjectArea"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#used -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#used">
        <owl:inverseOf rdf:resource="http://www.w3.org/ns/prov#wasGeneratedBy"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#Activity"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:isDefinedBy>Activity uses the entity which is index key</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#wasAssociatedWith -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasAssociatedWith">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#Activity"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/mc2/tbox#Agent"/>
        <rdfs:isDefinedBy>any activity occured was associated with an agent</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#wasGeneratedBy -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasGeneratedBy">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:range rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#Activity"/>
        <rdfs:isDefinedBy>Generation is the completion of production of a new entity by an activity. This entity did not exist before generation and becomes available for usage after this generation.</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.hds.utc.fr/tgc/tbox#First_Language -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#First_Language">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:isDefinedBy>the first preferred language for the person</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#experienceLevel -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#experienceLevel">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#Experience"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:isDefinedBy>Representes the numeric value equivaent to the teache&apos;s gamification or pedagogical experience level: expert=4, intermediate=3, beginner=2, novice=1</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#gender -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#gender">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:isDefinedBy>the gender preference of a person</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasPedagogicalPurpose -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasPedagogicalPurpose">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#Document"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#GamifiedResource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:isDefinedBy>the teacher defines the purpose of the resource as either for &quot;lecturing&quot; or for &quot;assessment&quot;</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#hasRequirementType -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#hasRequirementType">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#Document"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#GamifiedResource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:isDefinedBy>has priority indicates whether the presented pedagogical resource is an &quot;essential&quot; or &quot;bonus&quot;
pedagogical resources can be documents, or gamified resource which is a document with atleast one game element</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_EducationalLevel -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_EducationalLevel">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:isDefinedBy>The targeted audience of a targeted course has targeted educational level to be beginner, intermefdiate, or advanced</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_LearningPace -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_LearningPace">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#OnlineCourse"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:isDefinedBy>Whether the online course is flexible &apos;0&apos; or has certain deadlines &apos;1&apos;</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_Name -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_Name">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_PaymentPreference -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_PaymentPreference">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#OnlineCourse"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:isDefinedBy>The online course is  either &quot;free of charge&quot; or &quot;with charge&quot;</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_PoleValue -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_PoleValue">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#InputPole"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#PerceptionPole"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#ProcessingPole"/>
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#UnderstandingPole"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:isDefinedBy>indicates the value for each of the four poles of learning style</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_Rating -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_Rating">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#OnlineCourse"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:isDefinedBy>rating of course from 0 to 5.</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_TeachingLanguage -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_TeachingLanguage">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#OnlineCourse"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:isDefinedBy>the original language inwhich the course is created with</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_TeachingStyle -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_TeachingStyle">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:isDefinedBy>each teacher has teaching style</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_TotalCompletionHours -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_TotalCompletionHours">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:isDefinedBy>Number of hours for completing the course</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_TotalEnrollment -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_TotalEnrollment">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#OnlineCourse"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:isDefinedBy>total number of learners enrolled to the course throughout the years</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_URL -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_URL">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:isDefinedBy>the url of the game elment where it can be downloaded. In addition, this url contains information of the game elemnt.</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_age -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_age">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#unsignedInt"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_description -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_description">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:isDefinedBy>brief description of the game element purpose
ex: timer helps in maintaing focus and limiting distraction</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_duration -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_duration">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:isDefinedBy>The duration in minutes of a single resource</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_latestRelease -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_latestRelease">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:isDefinedBy>the number of weeks since the latest release of the game element version</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_latestVersion -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_latestVersion">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:isDefinedBy>the latest version released for this game element
ex: 1.0.3</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_title -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_title">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:isDefinedBy>the title of the resource</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_totalDownloads -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_totalDownloads">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:isDefinedBy>Total number of downloads done by users for this game element</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_totalLikes -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_totalLikes">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:isDefinedBy>Total number of likes granted for this game element</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#has_totalSites -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#has_totalSites">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:isDefinedBy>total websites that have sited/integrated this game element</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#knowledgeLevel -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#knowledgeLevel">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/tgc/tbox#TopicKnowledge"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:isDefinedBy>Representes the numeric value equivaent to  the level of person&apos;s knowledge in an educational topic</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>the knowledge level in a topic, it can vary from beginner, intermediate, advanced, and expert</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#second_Language -->

    <owl:DatatypeProperty rdf:about="http://www.hds.utc.fr/tgc/tbox#second_Language">
        <rdfs:domain rdf:resource="http://www.hds.utc.fr/mc2/tbox#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:isDefinedBy>the second  preferred language for the person</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.hds.utc.fr/mc2.1/tbox#Activity -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2.1/tbox#Activity">
        <rdfs:isDefinedBy>represents the processes and procedures done over time</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2.1/tbox#Space -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2.1/tbox#Space">
        <rdfs:isDefinedBy>A collaborative area with user accounts that are members in that space to help share resources</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2.1/tbox#UserAccount -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2.1/tbox#UserAccount">
        <rdfs:isDefinedBy>Each person involved in the work process has one account or more. The account is
associated with a role.</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2.1/tbox#UserGroup -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2.1/tbox#UserGroup">
        <rdfs:isDefinedBy>Users can be members in different
groups, and each group has a corresponding shared space allowing its members to collaborate</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#AccessResourceActivity -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#AccessResourceActivity">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#InteractionActivityOnResources"/>
        <rdfs:isDefinedBy>The activity of accessing a resource in the platform;</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#AddResourceActivity -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#AddResourceActivity">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#InteractionActivityOnResources"/>
        <rdfs:isDefinedBy>The activity of adding a resource in the platform which does not
exist before, but is not created originally by the user who adds it;</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#Agent -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#Agent">
        <rdfs:comment>The Agent class is the class of agents; things that do stuff. A well known sub-class is Person, representing people. Other kinds of agents include Organization and Group.</rdfs:comment>
        <rdfs:comment>The Group class represents a collection of individual agents (and may itself play the role of a Agent, ie. something that can perform actions).</rdfs:comment>
        <rdfs:isDefinedBy>An agent (eg. person, group, software or physical artifact).</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#CompositeResource -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#CompositeResource">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#Resource"/>
        <rdfs:comment>Composite resource contains one or more simple resource</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#CreateResourceActivity -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#CreateResourceActivity">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#InteractionActivityOnResources"/>
        <rdfs:isDefinedBy>The activity of creating an original resource in the platform,
e.g., creating a note;</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#DeleteResourceActivity -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#DeleteResourceActivity">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#InteractionActivityOnResources"/>
        <rdfs:isDefinedBy>The activity of deleting a resource in the platform;</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#Document -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#Document">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#SimpleResource"/>
        <rdfs:comment>in memorae, document is equivalent to bibo:document which consists of: image, article, audio, book, slideshow, etc.</rdfs:comment>
        <rdfs:isDefinedBy>provide structured content and information on specific subjects or topics in the form of e-books, textbooks and reference materials.</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#IndexKey -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#IndexKey">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <owl:disjointWith rdf:resource="http://www.hds.utc.fr/mc2sois/tbox#ReferenceKey"/>
        <rdfs:comment>Each resource is referenced by an index key that is visible at a group space.
This ties a resource to a group</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#InstituationalGroup -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#InstituationalGroup">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#UserGroup"/>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#InteractionActivity -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#InteractionActivity">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#Activity"/>
        <rdfs:isDefinedBy>representing interaction activities and administration activities in the virtual environment</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#InteractionActivityOnResources -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#InteractionActivityOnResources">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#InteractionActivity"/>
        <rdfs:comment>Each interaction activity takes place over a time period and acts on or
with resources. This can compose and generate individual activity traces. Each trace belongs
to an individual and is linked to the index key of the concerned resource.</rdfs:comment>
        <rdfs:isDefinedBy>representing interaction activities in the virtual environment</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#ModifyResourceActivity -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#ModifyResourceActivity">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#InteractionActivityOnResources"/>
        <rdfs:isDefinedBy>The activity of modifying a resource in the platform;</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#Person -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#Person">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#Agent"/>
        <rdfs:isDefinedBy>Each person involved in the work process has one account or more. 
Every person has a personal group which holds a personal sharing space.</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#PersonalGroup -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#PersonalGroup">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2.1/tbox#UserGroup"/>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#Resource -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#Resource">
        <owl:disjointWith rdf:resource="http://www.hds.utc.fr/tco/tbox#Lesson"/>
        <rdfs:comment>Resources can be simple resource or composite resource</rdfs:comment>
        <rdfs:isDefinedBy>encompass materials and tools supporting teaching and
learning, such as textbooks, online courses, multimedia content, software,
research articles, and interactive resources</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#ShareResourceActivity -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#ShareResourceActivity">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#InteractionActivityOnResources"/>
        <rdfs:isDefinedBy>The activity of sharing a resource in the platform, e.g., sharing
with another group a document which is already added to the platform.</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#SimpleResource -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#SimpleResource">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#Resource"/>
        <rdfs:comment>A single resource like game element, document, video, etc.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2/tbox#Vote -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2/tbox#Vote">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#SimpleResource"/>
        <rdfs:comment>The vote is modeled as a simple resource for mainly three reasons:
• Modeling Vote as a resource make it possible to index it by an index key that is
visible in a certain sharing space;
• A vote is created by a user;
• Vote can further be used for reasoning the competency of a user who has created,
shared or modified the voted resource.</rdfs:comment>
        <rdfs:isDefinedBy>Users have different preferences on resources for different purposes. They
express these preferences on the resources by giving a value between 1 and 5, the higher the value, the more they appreciate the resource.</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2sois/tbox#ReferenceKey -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2sois/tbox#ReferenceKey">
        <rdfs:comment>provide users access to the resource through a reference key.
Each resource has reference key that is indexed by index key</rdfs:comment>
        <rdfs:seeAlso>IndexKey</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/mc2sois/tbox#User -->

    <owl:Class rdf:about="http://www.hds.utc.fr/mc2sois/tbox#User">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#Person"/>
        <rdfs:comment>Prof.Abel requested to use Mc2:User, however, it is of no use since it is not really associated to anything, 
MC2:has_user_account has domain as MC2:Person and range as MC2:UserAccount
So a person can directly have a user account

mc2sois is no loger used.</rdfs:comment>
        <rdfs:isDefinedBy>users who communicate with each other by using the Usergroup class. This class is useful when describing groups of users within a social Web application.

A Person can exist without being a user in a group</rdfs:isDefinedBy>
        <owl:deprecated></owl:deprecated>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tco/tbox#Course -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tco/tbox#Course">
        <rdfs:isDefinedBy>A course is an individual subject component consisting of lessons and resources</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tco/tbox#EducationalInstitution -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tco/tbox#EducationalInstitution">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.hds.utc.fr/tgc/tbox#offersCourse"/>
                <owl:someValuesFrom rdf:resource="http://www.hds.utc.fr/tco/tbox#Course"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy>An educational institution is a place where people of different ages gain an education</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tco/tbox#Learner -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tco/tbox#Learner">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#Person"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.hds.utc.fr/tgc/tbox#hasLearningStyle"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#InputPole"/>
                            <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#PerceptionPole"/>
                            <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#ProcessingPole"/>
                            <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#UnderstandingPole"/>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.hds.utc.fr/tgc/tbox#hasPlayerType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#Free_Spirit"/>
                            <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#Group_Learning"/>
                            <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#Philanthropist"/>
                            <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#Socializer"/>
                        </owl:oneOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
        <rdfs:comment>A Learner can be a user if he has a user account</rdfs:comment>
        <rdfs:isDefinedBy>A learner engages in knowledge, skill, or competency acquisition through education or training</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tco/tbox#Lesson -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tco/tbox#Lesson">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.hds.utc.fr/tgc/tbox#CoversTopic"/>
                <owl:someValuesFrom rdf:resource="http://www.hds.utc.fr/tgc/tbox#EducationalTopic"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy>A part of the course about a specific objective</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tco/tbox#Teacher -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tco/tbox#Teacher">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#Person"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.hds.utc.fr/tgc/tbox#sharesSpaceWith"/>
                <owl:someValuesFrom rdf:resource="http://www.hds.utc.fr/tco/tbox#Teacher"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.hds.utc.fr/tgc/tbox#hasPlayerType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#Free_Spirit"/>
                            <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#Group_Learning"/>
                            <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#Philanthropist"/>
                            <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#Socializer"/>
                        </owl:oneOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A Teacher can be a user if he has user account</rdfs:comment>
        <rdfs:isDefinedBy>A teacher is an individual responsible for facilitating learning, designing lessons,
assessing learner progress, and creating a supportive learning environment</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tco/tbox#WorkingEnvironment -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tco/tbox#WorkingEnvironment"/>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#Achievement -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#Achievement">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:isDefinedBy>Adding achievement milestone after a learner progresses in a group of resources</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#Audience -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#Audience">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.hds.utc.fr/tgc/tbox#isComposedOf"/>
                <owl:someValuesFrom rdf:resource="http://www.hds.utc.fr/tco/tbox#Learner"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy>a particular group at which a course is aimed.</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#Badge -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#Badge">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:isDefinedBy>Virtual design that reward players for achieving specific milestones or completing particular tasks</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#BehaviouralObjective -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#BehaviouralObjective">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#Exploration"/>
                    <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#Group_Learning"/>
                    <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#Motivation"/>
                    <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#Participation"/>
                    <rdf:Description rdf:about="http://www.hds.utc.fr/tgc/tbox#Performance"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#Objective"/>
        <rdfs:isDefinedBy>objectives the teacher can choose from for each resource to prompt a desired learners’ behaviours when learners interact with that resource.
They are:
Motivation, Performance, Group Learning, Participation, and Exploration</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#BonusPoints -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#BonusPoints">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#Points"/>
        <rdfs:isDefinedBy>Points offered upon accomplishing bonus resources</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#BonusPointsLeaderboard -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#BonusPointsLeaderboard">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#Leaderboard"/>
        <rdfs:isDefinedBy>Special type of leaderboard for the bonus points offered upon accomplishing bonus resources</rdfs:isDefinedBy>
        <rdfs:seeAlso>BonusPoints</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#Challenge -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#Challenge">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:isDefinedBy>Slightly harder resource in which learners solve a particular problem or complete a challenge task</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#ClassroomObjective -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#ClassroomObjective"/>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#DigitalContent_Competency -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#DigitalContent_Competency">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#Digital_Competency"/>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#Digital_Competency -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#Digital_Competency"/>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#EducationalTopic -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#EducationalTopic">
        <rdfs:isDefinedBy>refers to the subject matter or themes within the course</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#Experience -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#Experience">
        <rdfs:isDefinedBy>The teachers&apos; experience in pedagogy and gamification</rdfs:isDefinedBy>
        <rdfs:seeAlso>PedagogicalExperience
GamificationExperience</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#ExperiencePoints -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#ExperiencePoints">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#Points"/>
        <rdfs:comment>Points accumulated accross resources</rdfs:comment>
        <rdfs:isDefinedBy>Experience points, often abbreviated as XP, are a quantifiable representation of a learner&apos;s progress and skill level in a course.</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#ExperiencePointsLeaderboard -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#ExperiencePointsLeaderboard">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#Leaderboard"/>
        <rdfs:isDefinedBy>Special type of leaderboard for experience points</rdfs:isDefinedBy>
        <rdfs:seeAlso>ExperiencePoints</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#Feedback -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#Feedback">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:isDefinedBy>A reaction triggered following the learners&apos;s interaction with gamified resource</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#GameElementResource -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#GameElementResource">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#SimpleResource"/>
        <rdfs:isDefinedBy>The components that build up a game.</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#GamificationExperience -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#GamificationExperience">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#Experience"/>
        <rdfs:isDefinedBy>teacher excperience in understanding and application of the gamification concepts</rdfs:isDefinedBy>
        <rdfs:seeAlso>GameElementResource</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#GamifiedResource -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#GamifiedResource">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/mc2/tbox#CompositeResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.hds.utc.fr/tgc/tbox#containsGameElement"/>
                <owl:someValuesFrom rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy>A composite resource that has any pedagogical resource such as document/video/etc, in addition to one or more game element</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#Hint -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#Hint">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:isDefinedBy>A guidance provided to learners for solving the resource</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#InputPole -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#InputPole">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#LearningStyle"/>
        <rdfs:isDefinedBy>Input pole is either Visual or Verbal</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#Leaderboard -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#Leaderboard">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:isDefinedBy>a scoreboard showing the names and current points of the leading competitors within a course or a single resource</rdfs:isDefinedBy>
        <rdfs:seeAlso>Points</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#LearningStyle -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#LearningStyle">
        <rdfs:comment>Learning styles according to Felder and Silverman consist of four dimensions: input, perceprion, processing, and understanding</rdfs:comment>
        <rdfs:isDefinedBy>a set of factors, behaviors, and attitudes that facilitate learning for a learner in a given situation</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#Level -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#Level">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tgc/tbox#GameElementResource"/>
        <rdfs:isDefinedBy>visualizing a resource or group of resources as levels</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#Objective -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#Objective">
        <rdfs:isDefinedBy>Teacher&apos;s objective behind the represented resource</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.hds.utc.fr/tgc/tbox#OnlineCourse -->

    <owl:Class rdf:about="http://www.hds.utc.fr/tgc/tbox#OnlineCourse">
        <rdfs:subClassOf rdf:resource="http://www.hds.utc.fr/tco/tbox#Course"/>
